PORT=4000
NODE_ENV=development

# --- Database --------------------------------------------------------------
# Option A: single connection string (what Railway / PlanetScale / Heroku hand
# you). If MYSQL_URL or DATABASE_URL is set, the DB_* vars below are ignored.
# MYSQL_URL=mysql://user:pass@host:3306/dbname

# Option B: discrete vars (used for local docker-compose).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=hmis
DB_PASSWORD=hmis_secret
DB_NAME=hmis

# --- Auth ------------------------------------------------------------------
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=8h

# --- CORS ------------------------------------------------------------------
# Comma-separated origins. Vite default: http://localhost:5173
# In production, add your Vercel URL, e.g.:
# CORS_ORIGIN=http://localhost:5173,https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173
